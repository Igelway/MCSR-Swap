# Copy this file to .env and adjust the values.
# Run `just setup-env` (or `just up`) to auto-generate .forwarding.secret.

# ── User / permissions ────────────────────────────────────────────────────────
# UID/GID of the user that owns the data directories on the host.
# Run `id -u` / `id -g` to find your values.
# PUID=1000
# PGID=1000

# ── Velocity proxy ────────────────────────────────────────────────────────────
# Whether Velocity authenticates players with Mojang (online-mode).
# Set to false for LAN / offline play.
VELOCITY_ONLINE_MODE=true
# Player info forwarding mode: none, legacy, modern, bungeeguard (only patched if set)
# VELOCITY_FORWARDING_MODE=modern

# ── Game server data (Docker mode) ───────────────────────────────────────────
# Absolute host path where per-game-server data directories are stored.
# MUST be an absolute path (e.g. /home/user/mcsr-swap/data).
# Required when docker.enabled=true in config.yml — the plugin will not start without it.
# Defaults to <project-dir>/data when using `just up` — servers land at ./data/game1, ./data/game2 etc.
# GAME_DATA_DIR=

# ── Docker images ─────────────────────────────────────────────────────────────
# Override to use locally built images (e.g. after `just docker-build`).
# MCSRSWAP_VELOCITY_IMAGE=ghcr.io/igelway/mcsr-swap-velocity:latest
# MCSRSWAP_GAMESERVER_IMAGE=ghcr.io/igelway/mcsr-swap-gameserver:latest

# ── Docker networking (advanced) ──────────────────────────────────────────────
# Usually no need to change these.
# MCSRSWAP_LOBBY_ADDRESS=lobby
# MCSRSWAP_DOCKER_NETWORK=mcsrswap-network
# MCSRSWAP_DOCKER_HOST=tcp://docker-proxy:2375

# ── Plugin settings ───────────────────────────────────────────────────────────
# Comma-separated list of admin UUIDs or usernames. Extends the admins list from config.yml.
# MCSRSWAP_ADMINS=069a79f4-44e9-4726-a5be-fca90e38aaf9,SomeUsername

# Set to false to skip pulling the game server image on startup (useful with locally built images).
# MCSRSWAP_PULL_GAME_IMAGE=true

# ── Game server settings ──────────────────────────────────────────────────────
# These variables are passed directly to each spawned game server container.
# The MCSRSWAP_GAME_ prefix is stripped before forwarding, e.g.:
#   MCSRSWAP_GAME_OPS=Player1  →  OPS=Player1 inside the container
# Full list of supported variables: https://docker-minecraft-server.readthedocs.io/en/latest/

# Op (admin) players on the game servers.
# MCSRSWAP_GAME_OPS=

# Game difficulty (easy/normal/hard). Default: easy
# MCSRSWAP_GAME_DIFFICULTY=easy

# Maximum number of players per game server.
# MCSRSWAP_GAME_MAX_PLAYERS=20

# Memory allocated to each game server (e.g. 2G, 4G).
# MCSRSWAP_GAME_MEMORY=2G

# ── Secrets (separate files) ──────────────────────────────────────────────────
# .forwarding.secret  – Velocity forwarding secret shared with all backend servers.
#                      Generated automatically by `just setup-env`.
#
# .playit.secret      – playit.gg agent key (only needed with `just up --tunnel`).
#                      Create with: echo '<your-key>' > .playit.secret
#                      Get your key at: https://playit.gg/account/agents/new-docker
