# Copy this file to .env and adjust the values as needed.
# If .env does not exist, `just up` / `just setup-env` will create it from this file.
# Most settings are optional — sensible defaults are provided.

# ── Velocity proxy ────────────────────────────────────────────────────────────
# Whether Velocity authenticates players with Mojang (online-mode).
# Set to false for LAN / offline play.
# VELOCITY_ONLINE_MODE=true

# Player info forwarding mode: none, legacy, modern, bungeeguard
# VELOCITY_FORWARDING_MODE=modern

# ── Admin permissions ─────────────────────────────────────────────────────────
# Comma-separated list of admin UUIDs or usernames. Extends the admins list from config.yml.
# MCSRSWAP_ADMINS=069a79f4-44e9-4726-a5be-fca90e38aaf9,SomeUsername

# ── Game server settings ──────────────────────────────────────────────────────
# Required: accept the Minecraft EULA before starting containers.
# Variables prefixed with MCSRSWAP_GAME_ are passed to each spawned game server container.
# The prefix is stripped before forwarding, e.g. MCSRSWAP_GAME_OPS=Player1 → OPS=Player1
# Full list: https://docker-minecraft-server.readthedocs.io/en/latest/configuration/server-properties/

# Comma-separated list of Op (admin) players on the game servers.
# MCSRSWAP_GAME_OPS=

# Game server view distance
# MCSRSWAP_GAME_VIEW_DISTANCE=20

# Game difficulty (peaceful/easy/normal/hard). Default: easy
# MCSRSWAP_GAME_DIFFICULTY=easy

# Maximum players per game server.
# MCSRSWAP_GAME_MAX_PLAYERS=20
# Memory allocated to each game server(e.g. 2G, 4G).
# MCSRSWAP_GAME_MEMORY=2G

# For both gameserver and lobby:
# `just up` will ask for confirmation and write this value to .env if it is missing.
# MINECRAFT_SERVER_EULA=false

# ── Advanced Docker settings ──────────────────────────────────────────────────
# Host path where game server data is stored. Defaults to <project-dir>/data
# Only set this if you need a custom location (must be absolute path).
# GAME_DATA_DIR=

# Override to use locally built images (e.g. after `just docker-build`).
# MCSRSWAP_VELOCITY_IMAGE=ghcr.io/local/mcsr-swap-velocity:latest
# MCSRSWAP_GAMESERVER_IMAGE=ghcr.io/local/mcsr-swap-gameserver:latest
# MCSRSWAP_LIMBO_IMAGE=ghcr.io/local/mcsr-swap-limbo:latest

# Skip automatic image pull on startup (useful with locally built images).
# MCSRSWAP_PULL_GAME_IMAGE=false

# Docker Compose profiles to enable by default.
# Set to `playit` to always start the optional playit.gg tunnel with `just up`.
# If you use multiple profiles, separate them with commas, e.g. COMPOSE_PROFILES=foo,playit
# COMPOSE_PROFILES=playit

# UID/GID for container file ownership (defaults to current user).
# PUID=1000
# PGID=1000

# Internal Docker networking (rarely needs changing).
# MCSRSWAP_LOBBY_ADDRESS=lobby
# MCSRSWAP_LIMBO_ADDRESS=limbo
# MCSRSWAP_DOCKER_NETWORK=mcsrswap-network
# MCSRSWAP_DOCKER_HOST=tcp://docker-proxy:2375

# ── Chunky pre-generation (optional) ─────────────────────────────────────────
# Set to true to enable automatic chunk pre-generation on game server startup.
# Carpet and Chunky mods are always bundled in the game server image.
# The game server will generate chunks before signalling ready, increasing startup time.
# MCSRSWAP_CHUNKY_PRELOAD=false
# MCSRSWAP_CHUNKY_OW_RADIUS=200
# MCSRSWAP_CHUNKY_NETHER_RADIUS=200
# MCSRSWAP_CHUNKY_END_RADIUS=200

# ── Secrets (separate files) ──────────────────────────────────────────────────
# .forwarding.secret  – Velocity forwarding secret (auto-generated by `just up`)
# .playit.secret      – playit.gg agent key (needed with `just up --playit`
#                       or COMPOSE_PROFILES including `playit`)
#                       Get your key at: https://playit.gg → Add Agent → Docker
