# Example .env file for docker-compose
# Copy this to .env and adjust if using a fork

# Velocity proxy image (default uses official relacibo/mcsr-swap)
# MCSRSWAP_VELOCITY_IMAGE=ghcr.io/your-username/mcsr-swap-velocity:latest

# Game server image is auto-detected from GITHUB_REPOSITORY env in plugin
# But you can override it here:
# MCSRSWAP_GAMESERVER_IMAGE=ghcr.io/your-username/mcsr-swap-gameserver:latest

# User and group IDs for proper file permissions (default: 1000)
# Use `id` to find your values
PUID=1000
PGID=1000
